// Prisma schema for Worlog — A Passport of Things Logged.
//
// Local dev uses SQLite for zero-setup. To move to production Postgres:
//   1. set `provider = "postgresql"` below
//   2. set DATABASE_URL to your Postgres connection string
//   3. run `npx prisma migrate dev`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  theme        String   @default("Sepia Atlas") // remembered light/dark choice
  createdAt    DateTime @default(now())

  entries Entry[]
}

// A logged experience tied to a country. Country identity lives in the shared
// catalog (src/lib/countries.ts) keyed by the world-atlas numeric id, so we
// only store the id here and resolve name/region/coordinates at render time.
model Entry {
  id        String   @id @default(cuid())
  userId    String
  countryId String // world-atlas numeric country id, e.g. "392" for Japan
  // Additional countries the entry covers (a book spanning several countries
  // is logged once and appears under each). CSV of catalog ids, "" for none;
  // countryId stays the primary and is never repeated here.
  extraCountries String @default("")
  category  String // recipe | book | movie | music | place
  // Wish-list entries are things the user wants to do/make. They live in the
  // same table but don't count as logs: the map doesn't color for them and
  // they're tallied separately everywhere.
  wishlist  Boolean  @default(false)
  title     String
  by        String   @default("")
  note      String   @default("")
  link      String   @default("") // optional URL associated with the entry
  // Calendar date the entry is logged for, as "yyyy-mm-dd" (a date-only string
  // sidesteps timezone shifts). Empty for entries that predate the field;
  // `year` is derived from it at write time and stays the grouping field.
  date      String   @default("")
  year      Int
  // Review rating, 1–5 stars; null = unrated.
  rating    Int?
  // Recipe-only: the dish is a national dish of the countries it's logged
  // under. Always false for other categories.
  nationalDish Boolean @default(false)
  // Optional attachment (currently used for recipe uploads). The file is stored
  // on the persistent volume under UPLOAD_DIR; fileKey is its on-disk name.
  fileName  String?
  fileKey   String?
  fileType  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, countryId])
}
