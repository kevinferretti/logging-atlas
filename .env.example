# Copy to .env and fill in.

# SQLite for local dev. For production use Postgres, e.g.:
#   DATABASE_URL="postgresql://user:pass@host:5432/atlas?schema=public"
# and set `provider = "postgresql"` in prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Secret used to sign session JWTs. Generate with: openssl rand -base64 48
AUTH_SECRET="change-me"

# Public base URL of the app — used for links written to the server log
# (password resets). Set it in production so a forged Host header can't
# poison those links; when unset, the request's host is used (fine for dev).
# APP_URL="https://atlas.example.com"
